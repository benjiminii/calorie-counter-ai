EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_KEY_HERE
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

CONVEX_DEPLOYMENT=YOUR-DEPLOYMENT
EXPO_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://YOUR-DEPLOYMENT.convex.cloud

# Set on the Convex deployment (not in this file): `npx convex env set CLERK_JWT_ISSUER_DOMAIN ...`
CLERK_JWT_ISSUER_DOMAIN=https://YOUR-CLERK-ISSUER.clerk.accounts.dev

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.YOUR_IOS_CLIENT_ID

# ────────────────────────────────────────────────────────────────────────────
# QPay — do NOT put these in .env.local. They must live on the Convex
# deployment so they never ship in the app bundle. Listed here for reference:
#
#   npx convex env set QPAY_BASE_URL https://merchant-sandbox.qpay.mn
#   npx convex env set QPAY_USERNAME YOUR_QPAY_USERNAME
#   npx convex env set QPAY_PASSWORD YOUR_QPAY_PASSWORD
#   npx convex env set QPAY_INVOICE_CODE YOUR_QPAY_INVOICE_CODE
#
# Use the production host once your merchant account is approved:
#   npx convex env set QPAY_BASE_URL https://merchant.qpay.mn
#
# The QPay dashboard callback URL for this deployment is:
#   ${CONVEX_SITE_URL}/qpay/callback
# ────────────────────────────────────────────────────────────────────────────
